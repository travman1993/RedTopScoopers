# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Admin Auth ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=redtopscoopers@gmail.com
ADMIN_PASSWORD=your-secure-password-here

# Long random string — used to sign the admin session cookie.
# Generate one: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get from: https://dashboard.stripe.com/webhooks (after adding the webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (email) ──────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# Must match a verified domain in your Resend account
# e.g.  noreply@redtopscoopers.com
RESEND_FROM_EMAIL=noreply@redtopscoopers.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://redtopscoopers.com
